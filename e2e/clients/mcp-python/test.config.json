{
  "name": "mcp-python",
  "type": "client",
  "transport": "mcp",
  "language": "python",
  "protocolFamilies": [
    "evm",
    "tvm"
  ],
  "x402Versions": [
    2
  ],
  "evm": {
    "transferMethods": [
      "eip3009"
    ]
  },
  "environment": {
    "required": [
      "RESOURCE_SERVER_URL",
      "ENDPOINT_PATH"
    ],
    "optional": [
      "EVM_PRIVATE_KEY",
      "TVM_PRIVATE_KEY",
      "TVM_NETWORK",
      "TONCENTER_API_KEY",
      "TONCENTER_BASE_URL"
    ]
  }
}
