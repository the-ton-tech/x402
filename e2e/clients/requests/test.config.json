{
  "name": "requests",
  "type": "client",
  "language": "python",
  "protocolFamilies": [
    "evm",
    "svm",
    "tvm"
  ],
  "x402Versions": [
    1,
    2
  ],
  "evm": {
    "transferMethods": ["eip3009", "permit2"]
  },
  "extensions": [
    "eip2612GasSponsoring",
    "erc20ApprovalGasSponsoring"
  ],
  "description": "Python requests client with x402 v2 HTTP adapter",
  "environment": {
    "required": [
      "RESOURCE_SERVER_URL",
      "ENDPOINT_PATH"
    ],
    "optional": [
      "EVM_PRIVATE_KEY",
      "SVM_PRIVATE_KEY",
      "TVM_PRIVATE_KEY",
      "EVM_RPC_URL",
      "TVM_NETWORK",
      "TONCENTER_API_KEY",
      "TONCENTER_BASE_URL"
    ]
  }
}
